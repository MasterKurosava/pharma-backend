generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PaymentStatusCode {
  UNPAID
  PREPAID_50
  PAID
}

enum ProductAvailabilityStatus {
  OUT_OF_STOCK
  ON_REQUEST
  IN_STOCK
}

enum OrderStatusType {
  ACTION
  STATE
  ASSEMBLY
}

enum OrderTableGroup {
  REQUESTS
  PICKUP
  ALMATY_DELIVERY
  RK_DELIVERY
  ARCHIVE
}

model Role {
  id                     Int               @id @default(autoincrement())
  name                   String            @unique
  code                   String            @unique
  isSystem               Boolean           @default(false)
  allowedRoutes          String[]          @default([])
  allowedOrderTableGroups OrderTableGroup[] @default([])
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt

  users User[]
}

model User {
  id           Int       @id @default(autoincrement())
  login        String    @unique
  email        String?   @unique
  passwordHash String
  firstName    String?   @map("first_name")
  lastName     String?   @map("last_name")
  name         String?
  roleId       Int
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  role Role @relation(fields: [roleId], references: [id])

  productStockMovements ProductStockMovement[] @relation("ProductStockMovementCreatedByUser")

  @@index([roleId])
}

model Manufacturer {
  id        Int      @id @default(autoincrement())
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]
}

model ActiveSubstance {
  id        Int      @id @default(autoincrement())
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]
}

model ProductOrderSource {
  id        Int      @id @default(autoincrement())
  name      String
  color     String?
  isActive  Boolean  @default(true)
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]
}

model Product {
  id                   Int      @id @default(autoincrement())
  name                 String
  description          String?
  imageUrl             String?
  manufacturerId       Int
  activeSubstanceId    Int
  availabilityStatus   ProductAvailabilityStatus @default(IN_STOCK)
  productOrderSourceId Int?
  storagePlaceId       Int?
  stockQuantity        Int      @default(0)
  reservedQuantity     Int      @default(0)
  price                Decimal  @db.Decimal(10, 2)
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  manufacturer Manufacturer      @relation(fields: [manufacturerId], references: [id])
  activeSubstance ActiveSubstance @relation(fields: [activeSubstanceId], references: [id])
  orderSource ProductOrderSource? @relation(fields: [productOrderSourceId], references: [id])
  storagePlace StoragePlace?      @relation(fields: [storagePlaceId], references: [id])

  orders Order[]
  stockMovements ProductStockMovement[]

  @@index([manufacturerId])
  @@index([activeSubstanceId])
  @@index([productOrderSourceId])
  @@index([storagePlaceId])
}

model ProductStockMovement {
  id              Int      @id @default(autoincrement())
  productId       Int
  orderId         Int?
  createdByUserId Int?
  type            String
  quantityDelta   Int
  beforeQuantity  Int
  afterQuantity   Int
  createdAt       DateTime @default(now())

  product       Product @relation(fields: [productId], references: [id])
  order         Order?  @relation(fields: [orderId], references: [id])
  createdByUser User?   @relation("ProductStockMovementCreatedByUser", fields: [createdByUserId], references: [id])

  @@index([productId])
  @@index([orderId])
  @@index([createdByUserId])
  @@index([type])
  @@index([createdAt])
}

model StoragePlace {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orders   Order[]
  products Product[]
}

model OrderStatusConfig {
  id                    Int             @id @default(autoincrement())
  code                  String          @unique
  type                  OrderStatusType
  name                  String
  color                 String?
  tableGroup            OrderTableGroup?
  reserveOnSet          Boolean         @default(false)
  writeOffOnSet         Boolean         @default(false)
  setAssemblyDateOnSet  Boolean         @default(false)
  isActive              Boolean         @default(true)
  sortOrder             Int             @default(0)
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  actionOrders Order[] @relation("OrderActionStatus")
  stateOrders  Order[] @relation("OrderStateStatus")

  @@index([type, isActive])
  @@index([tableGroup, isActive])
}

model AssemblyStatus {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  name      String
  color     String?
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders Order[]

  @@index([isActive, sortOrder])
}

model Order {
  id                          Int                @id @default(autoincrement())
  orderDate                   DateTime           @default(now())
  clientPhone                 String
  clientFullName              String?
  city                        String?
  address                     String?
  deliveryPrice               Decimal            @default(0) @db.Decimal(10, 2)
  itemsTotalPrice             Decimal            @default(0) @db.Decimal(10, 2)
  totalPrice                  Decimal            @default(0) @db.Decimal(10, 2)
  remainingAmount             Decimal            @default(0) @db.Decimal(10, 2)
  paymentStatus               PaymentStatusCode  @default(UNPAID)
  prepaymentDate              DateTime?
  paymentDate                 DateTime?
  assemblyDate                DateTime?
  actionStatusCode            String
  stateStatusCode             String
  assemblyStatusCode          String?
  storagePlaceId              Int?
  orderStorage                String?
  description                 String?
  productId                   Int
  productNameSnapshot         String
  productStatusNameSnapshot   String
  orderSourceNameSnapshot     String?
  manufacturerNameSnapshot    String
  activeSubstanceNameSnapshot String
  productPrice                Decimal            @db.Decimal(10, 2)
  quantity                    Int
  createdAt                   DateTime           @default(now())
  updatedAt                   DateTime           @updatedAt

  product      Product           @relation(fields: [productId], references: [id])
  actionStatus OrderStatusConfig @relation("OrderActionStatus", fields: [actionStatusCode], references: [code])
  stateStatus  OrderStatusConfig @relation("OrderStateStatus", fields: [stateStatusCode], references: [code])
  assemblyStatus AssemblyStatus?  @relation(fields: [assemblyStatusCode], references: [code])
  storagePlace StoragePlace?     @relation(fields: [storagePlaceId], references: [id])

  stockMovements ProductStockMovement[]

  @@index([city])
  @@index([storagePlaceId])
  @@index([paymentStatus])
  @@index([actionStatusCode])
  @@index([stateStatusCode])
  @@index([assemblyStatusCode])
  @@index([productId])
}