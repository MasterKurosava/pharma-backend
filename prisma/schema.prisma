generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderStatusCode {
  ORDER
  DELIVERY_REGISTRATION
  ADDRESS_REQUIRED
  ASSEMBLY_REQUIRED
  ASSEMBLED_WRITTEN_OFF
  PACKED
  CLOSED
}

enum DeliveryStatusCode {
  COLLECT_DOVAS
  COLLECT_PONY
  COLLECT_YANDEX
}

enum PaymentStatusCode {
  UNPAID
  PREPAID_50
  PAID
}

enum ProductAvailabilityStatus {
  OUT_OF_STOCK
  ON_REQUEST
  IN_STOCK
}

model Role {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  code      String   @unique
  isSystem  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[]
}

model User {
  id           Int       @id @default(autoincrement())
  login        String    @unique
  email        String?   @unique
  passwordHash String
  firstName    String?   @map("first_name")
  lastName     String?   @map("last_name")
  name         String?
  roleId       Int
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  role Role @relation(fields: [roleId], references: [id])

  productStockMovements ProductStockMovement[] @relation("ProductStockMovementCreatedByUser")

  @@index([roleId])
}

model Country {
  id        Int      @id @default(autoincrement())
  code      String?  @unique
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  manufacturers  Manufacturer[]
  orders         Order[]
}

model Manufacturer {
  id        Int      @id @default(autoincrement())
  name      String
  countryId Int?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  country Country? @relation(fields: [countryId], references: [id])

  products Product[]

  @@index([countryId])
}

model ActiveSubstance {
  id        Int      @id @default(autoincrement())
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]
}

model ProductOrderSource {
  id        Int      @id @default(autoincrement())
  name      String
  color     String?
  isActive  Boolean  @default(true)
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]
}

model Product {
  id                   Int      @id @default(autoincrement())
  name                 String
  description          String?
  imageUrl             String?
  manufacturerId       Int
  activeSubstanceId    Int
  availabilityStatus   ProductAvailabilityStatus @default(IN_STOCK)
  productOrderSourceId Int?
  stockQuantity        Int      @default(0)
  reservedQuantity     Int      @default(0)
  price                Decimal  @db.Decimal(10, 2)
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  manufacturer Manufacturer      @relation(fields: [manufacturerId], references: [id])
  activeSubstance ActiveSubstance @relation(fields: [activeSubstanceId], references: [id])
  orderSource ProductOrderSource? @relation(fields: [productOrderSourceId], references: [id])

  items OrderItem[]
  stockMovements ProductStockMovement[]

  @@index([manufacturerId])
  @@index([activeSubstanceId])
  @@index([productOrderSourceId])
}

model ProductStockMovement {
  id              Int      @id @default(autoincrement())
  productId       Int
  orderId         Int?
  createdByUserId Int?
  type            String
  quantityDelta   Int
  beforeQuantity  Int
  afterQuantity   Int
  createdAt       DateTime @default(now())

  product       Product @relation(fields: [productId], references: [id])
  order         Order?  @relation(fields: [orderId], references: [id])
  createdByUser User?   @relation("ProductStockMovementCreatedByUser", fields: [createdByUserId], references: [id])

  @@index([productId])
  @@index([orderId])
  @@index([createdByUserId])
  @@index([type])
  @@index([createdAt])
}

model StoragePlace {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orders Order[]
}

model Order {
  id                  Int      @id @default(autoincrement())
  orderDate           DateTime @default(now())
  clientPhone         String
  countryId           Int
  city                String
  address             String
  deliveryStatus      DeliveryStatusCode @default(COLLECT_DOVAS)
  deliveryPrice       Decimal  @default(0) @db.Decimal(10, 2)
  itemsTotalPrice     Decimal  @default(0) @db.Decimal(10, 2)
  totalPrice          Decimal  @default(0) @db.Decimal(10, 2)
  paidAmount          Decimal  @default(0) @db.Decimal(10, 2)
  remainingAmount     Decimal  @default(0) @db.Decimal(10, 2)
  paymentStatus       PaymentStatusCode @default(UNPAID)
  orderStatus         OrderStatusCode   @default(ORDER)
  storagePlaceId      Int?
  description         String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  country         Country          @relation(fields: [countryId], references: [id])
  storagePlace    StoragePlace?    @relation(fields: [storagePlaceId], references: [id])

  items OrderItem[]
  stockMovements ProductStockMovement[]

  @@index([countryId])
  @@index([city])
  @@index([storagePlaceId])
}

model OrderItem {
  id                         Int      @id @default(autoincrement())
  orderId                    Int
  productId                  Int
  productNameSnapshot        String
  productStatusNameSnapshot  String
  orderSourceNameSnapshot    String?
  manufacturerNameSnapshot   String
  activeSubstanceNameSnapshot String
  quantity                   Int
  pricePerItem               Decimal  @db.Decimal(10, 2)
  lineTotal                  Decimal  @db.Decimal(10, 2)
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  order   Order   @relation(fields: [orderId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}